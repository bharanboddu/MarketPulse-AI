# Flask Configuration
FLASK_SECRET_KEY=supersecretkeyreplaceinproduction
FLASK_ENV=development

# Database Settings
# Leave blank to use local SQLite (marketpulse.db)
# To use PostgreSQL, configure: postgresql://username:password@localhost:5432/marketpulsedb
DATABASE_URL=

# AI & LLM Service Keys (At least one is recommended for full AI summary features)
# Google Gemini API Key (Highly Recommended)
GEMINI_API_KEY=

# OpenAI API Key (Optional fallback)
OPENAI_API_KEY=

# External API Keys (Optional)
# NewsAPI Key (Optional, Google News RSS is used as free default)
NEWS_API_KEY=
